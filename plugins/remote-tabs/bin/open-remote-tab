#!/bin/sh
# Start a NEW background Claude Code remote-control session for the current
# project. Single POSIX entry point for the remote-tabs plugin; lives in bin/
# so the Bash tool puts it on PATH (Git Bash on Windows too).
#
# Detects the OS via `uname`:
#   - Windows (MINGW/MSYS/CYGWIN): hands off to scripts/open-remote-tab.ps1, which
#     starts the bridge with NO window (headless ConPTY host); only the no-pywinpty
#     fallback uses a minimized terminal.
#   - Linux / macOS: creates a detached tmux session running the same.
#
# NOTE: a `--remote-control` session is NOT saved locally — the conversation
# lives only on claude.ai/code (web); the local .jsonl is an empty stub.
set -e

root="$(pwd)"
proj="$(echo "$root" | tr 'A-Z' 'a-z' | tr ':/\\' '---')"
sec="$(date +%s)"
uid="$sec-$$"

case "$(uname -s)" in
  MINGW* | MSYS* | CYGWIN*)
    # Resolve sibling scripts/open-remote-tab.ps1 relative to this script.
    bindir="$(cd "$(dirname "$0")" && pwd)"
    ps1="$bindir/../scripts/open-remote-tab.ps1"
    if [ ! -f "$ps1" ]; then
      echo "open-remote-tab: launcher not found at $ps1" >&2
      exit 1
    fi
    ps1win="$(cygpath -w "$ps1")"
    # Run the .ps1 with NO console window. A console-less parent (the Bash tool's
    # shell) launching a console app (powershell) makes the default terminal
    # (Windows Terminal) pop a window to host it — a black flash that lingers the
    # ~0.4s until the .ps1 returns. -WindowStyle Hidden does NOT help (WT owns the
    # window). pythonw is a GUI-subsystem interpreter (no console of its own), so
    # going through it to launch powershell with CREATE_NO_WINDOW (0x08000000)
    # attaches no console at all — no window ever appears. powershell's stdout is
    # piped back so the status lines still show. pythonw missing (rare) -> direct
    # call (brief flash, old behavior).
    pyw="$(command -v pythonw 2>/dev/null)"
    if [ -n "$pyw" ]; then
      "$pyw" -c 'import subprocess,sys; r=subprocess.run(["powershell.exe","-ExecutionPolicy","Bypass","-File",sys.argv[1]],creationflags=0x08000000,capture_output=True,text=True); sys.stdout.write(r.stdout); sys.stderr.write(r.stderr); sys.exit(r.returncode)' "$ps1win"
    else
      powershell.exe -ExecutionPolicy Bypass -File "$ps1win"
    fi
    ;;
  *)
    if ! command -v tmux >/dev/null 2>&1; then
      echo "open-remote-tab: tmux is required. Install it (brew install tmux / apt install tmux) and retry." >&2
      exit 1
    fi
    name="claude-remote-$proj-$uid"
    claude_bin="$(command -v claude || echo "$HOME/.local/bin/claude")"
    inbox="${TMPDIR:-/tmp}/$name.inbox"
    : > "$inbox"
    # -e exports CLAUDE_BRIDGE_INBOX into the session so the model can find its own
    # inbox (e.g. `echo /clear >> "$CLAUDE_BRIDGE_INBOX"`). tmux send-keys then injects.
    tmux new-session -d -s "$name" -e "CLAUDE_BRIDGE_INBOX=$inbox" -c "$root" "$claude_bin --remote-control"
    # Start the keystroke bridge watcher in the background (exits when session ends).
    bindir="$(cd "$(dirname "$0")" && pwd)"
    nohup sh "$bindir/../scripts/bridge.sh" "$name" "$inbox" >/dev/null 2>&1 &
    echo "remote session started (tmux: $name) with keystroke bridge"
    echo "inbox: $inbox   (e.g. echo /clear >> \"$inbox\")"
    ;;
esac
